+++ b/src/main/java/com/portablestorage/Config.java
@@ -0,0 +1,25 @@
+package com.portablestorage;
+
+import java.io.File;
+
+import net.minecraftforge.common.config.Configuration;
+
+public final class Config {
+
+    private Config() {}
+
+    public static int magnetRadius = 8;
+
+    public static int clampRadius(int v) {
+        return Math.max(1, Math.min(128, v));
+    }
+
+    public static void load(File configFile) {
+        Configuration c = new Configuration(configFile);
+        c.load();
+        magnetRadius = clampRadius(c.getInt("magnetRadius", "magnet", 8, 1, 128, "磁铁吸取半径(格), 1-128"));
+        if (c.hasChanged()) {
+            c.save();
+        }
+    }
+}
