@@ -0,0 +1,42 @@
+package com.portablestorage;
+
+import java.io.File;
+import java.util.HashMap;
+import java.util.Map;
+
+import net.minecraft.server.MinecraftServer;
+import net.minecraftforge.event.world.WorldEvent;
+
+import com.portablestorage.db.StorageDao;
+import com.portablestorage.db.StorageDb;
+
+import cpw.mods.fml.common.eventhandler.SubscribeEvent;
+
+public class StorageProvider {
+
+    private static final Map<String, StorageDb> DBS = new HashMap<String, StorageDb>();
+
+    public static synchronized StorageDao dao() {
+        File dir = MinecraftServer.getServer()
+            .getEntityWorld()
+            .getSaveHandler()
+            .getWorldDirectory();
+        String key = dir.getAbsolutePath();
+        StorageDb db = DBS.get(key);
+        if (db == null) {
+            db = new StorageDb(new File(dir, "portablestorage/storage.db"));
+            DBS.put(key, db);
+        }
+        return new StorageDao(db);
+    }
+
+    @SubscribeEvent
+    public void onUnload(WorldEvent.Unload e) {
+        if (!e.world.isRemote && e.world.provider.dimensionId == 0) {
+            synchronized (StorageProvider.class) {
+                for (StorageDb db : DBS.values()) db.close();
+                DBS.clear();
+            }
+        }
+    }
+}
diff --git a/src/main/java/com/portablestorage/StorageService.java b/src/main/java/com/portablestorage/StorageService.java
new file mode 100644
index 0000000..73541e4
--- /dev/null
+++ b/src/main/java/com/portablestorage/StorageService.java
@@ -0,0 +1,116 @@
+package com.portablestorage;
+
+import java.util.ArrayList;
+import java.util.List;
+
+import net.minecraft.entity.player.EntityPlayerMP;
+import net.minecraft.item.ItemStack;
+
+import com.portablestorage.core.StoredItem;
+import com.portablestorage.db.StorageDao;
+import com.portablestorage.item.ItemPortableTerminal;
+import com.portablestorage.item.ItemStackCodec;
+import com.portablestorage.net.NetworkHandler;
+import com.portablestorage.net.PageResultPacket;
+
+public final class StorageService {
+
+    public static final int WINDOW = 90;
+
+    private StorageService() {}
+
+    public static void sendPage(EntityPlayerMP p, String keyword, int offset) {
+        StorageDao dao = StorageProvider.dao();
+        StorageDao.PageResult r = dao.queryWindowWithIds(
+            p.getUniqueID()
+                .toString(),
+            keyword,
+            offset,
+            WINDOW);
+        int n = r.items.size();
+        long[] ids = r.ids;
+        String[] items = new String[n];
+        int[] metas = new int[n];
+        long[] counts = new long[n];
+        String[] names = new String[n];
+        for (int i = 0; i < n; i++) {
+            items[i] = r.items.get(i)
+                .getItem();
+            metas[i] = r.items.get(i)
+                .getMeta();
+            counts[i] = r.items.get(i)
+                .getCount();
+            names[i] = r.items.get(i)
+                .getName();
+        }
+        NetworkHandler.INSTANCE.sendTo(new PageResultPacket(r.total, offset, ids, items, metas, counts, names), p);
+    }
+
+    public static void handleAction(EntityPlayerMP p, int action, long id, int amount, String keyword, int offset) {
+        StorageDao dao = StorageProvider.dao();
+        String uuid = p.getUniqueID()
+            .toString();
+        switch (action) {
+            case 0: // TAKE_STACK
+            case 2: // TAKE_TO_INV (same behavior)
+                takeToInventory(p, dao, uuid, id, -1);
+                break;
+            case 1: // TAKE_ONE
+                takeToInventory(p, dao, uuid, id, 1);
+                break;
+            case 3: // DEPOSIT_CURSOR
+                depositCursor(p, dao, uuid);
+                break;
+            case 4: // QUICK_DEPOSIT_ALL
+                quickDepositAll(p, dao, uuid);
+                break;
+            default:
+                break;
+        }
+        sendPage(p, keyword, offset);
+    }
+
+    private static void takeToInventory(EntityPlayerMP p, StorageDao dao, String uuid, long id, int requested) {
+        StoredItem si = dao.findById(uuid, id);
+        if (si == null) return;
+        int maxStack = ItemStackCodec.decode(si, 1)
+            .getMaxStackSize();
+        int want = requested < 0 ? maxStack : Math.min(requested, maxStack);
+        long took = dao.extract(uuid, id, want);
+        if (took <= 0) return;
+        ItemStack give = ItemStackCodec.decode(si, (int) took);
+        boolean added = p.inventory.addItemStackToInventory(give);
+        if (!added || give.stackSize > 0) {
+            int leftover = give.stackSize;
+            if (leftover > 0) {
+                StoredItem back = si.withCount(leftover);
+                dao.upsert(uuid, back);
+            }
+        }
+        p.inventoryContainer.detectAndSendChanges();
+        if (p.openContainer != null) p.openContainer.detectAndSendChanges();
+    }
+
+    private static void depositCursor(EntityPlayerMP p, StorageDao dao, String uuid) {
+        ItemStack held = p.inventory.getItemStack();
+        if (held == null) return;
+        dao.upsert(uuid, ItemStackCodec.encode(held));
+        p.inventory.setItemStack(null);
+        p.playerNetServerHandler
+            .sendPacket(new net.minecraft.network.play.server.S2FPacketSetSlot(-1, -1, p.inventory.getItemStack()));
+    }
+
+    private static void quickDepositAll(EntityPlayerMP p, StorageDao dao, String uuid) {
+        List<StoredItem> batch = new ArrayList<StoredItem>();
+        for (int i = 0; i < p.inventory.mainInventory.length; i++) {
+            ItemStack st = p.inventory.mainInventory[i];
+            if (st == null) continue;
+            if (st.getItem() instanceof ItemPortableTerminal) continue;
+            batch.add(ItemStackCodec.encode(st));
+            p.inventory.mainInventory[i] = null;
+        }
+        if (!batch.isEmpty()) dao.upsertBatch(uuid, batch);
+        p.inventoryContainer.detectAndSendChanges();
+        if (p.openContainer != null) p.openContainer.detectAndSendChanges();
+    }
+}
diff --git a/src/main/java/com/portablestorage/client/GuiPortableStorage.java b/src/main/java/com/portablestorage/client/GuiPortableStorage.java
new file mode 100644
index 0000000..26966da
--- /dev/null
+++ b/src/main/java/com/portablestorage/client/GuiPortableStorage.java
@@ -0,0 +1,246 @@
+package com.portablestorage.client;
+
+import java.util.ArrayList;
+import java.util.List;
+
+import net.minecraft.client.gui.GuiButton;
+import net.minecraft.client.gui.GuiTextField;
+import net.minecraft.client.gui.inventory.GuiContainer;
+import net.minecraft.client.renderer.RenderHelper;
+import net.minecraft.client.renderer.entity.RenderItem;
+import net.minecraft.inventory.Container;
+import net.minecraft.item.Item;
+import net.minecraft.item.ItemStack;
+
+import org.lwjgl.input.Keyboard;
+import org.lwjgl.input.Mouse;
+import org.lwjgl.opengl.GL11;
+
+import com.portablestorage.net.NetworkHandler;
+import com.portablestorage.net.PageResultPacket;
+
+public class GuiPortableStorage extends GuiContainer {
+
+    public static final int COLS = 9;
+    public static final int VIS_ROWS = 5;
+    public static final int WINDOW = 90;
+    private static final int SLOT = 18;
+    private static final int GRID_X = 8;
+    private static final int GRID_Y = 20;
+
+    private static volatile PageResultPacket pending;
+
+    private GuiTextField search;
+    private int rowOffset = 0;
+    private long total = 0;
+    private long[] ids = new long[0];
+    private String[] items = new String[0];
+    private int[] metas = new int[0];
+    private long[] counts = new long[0];
+    private String[] names = new String[0];
+    private String keyword = "";
+    private long lastTypeMs = 0;
+    private final RenderItem renderItem = new RenderItem();
+
+    public GuiPortableStorage(Container c) {
+        super(c);
+        this.xSize = 195;
+        this.ySize = 222;
+    }
+
+    public static void deliver(PageResultPacket p) {
+        pending = p;
+    }
+
+    @Override
+    public void initGui() {
+        super.initGui();
+        Keyboard.enableRepeatEvents(true);
+        this.search = new GuiTextField(this.fontRendererObj, this.guiLeft + 8, this.guiTop + 6, 150, 12);
+        this.search.setFocused(true);
+        this.search.setCanLoseFocus(true);
+        this.buttonList.clear();
+        this.buttonList.add(new GuiButton(1, this.guiLeft + 8, this.guiTop + 116, 80, 18, "一键收纳"));
+        requestWindow(0);
+    }
+
+    @Override
+    public void onGuiClosed() {
+        super.onGuiClosed();
+        Keyboard.enableRepeatEvents(false);
+    }
+
+    private void requestWindow(int rowOff) {
+        int maxRow = maxRowOffset();
+        if (rowOff < 0) rowOff = 0;
+        if (rowOff > maxRow) rowOff = maxRow;
+        this.rowOffset = rowOff;
+        NetworkHandler.requestPage(this.keyword, rowOff * COLS, WINDOW);
+    }
+
+    private int maxRowOffset() {
+        int rows = (int) Math.ceil(this.total / (double) COLS);
+        int m = rows - VIS_ROWS;
+        return m < 0 ? 0 : m;
+    }
+
+    @Override
+    public void updateScreen() {
+        super.updateScreen();
+        PageResultPacket p = pending;
+        if (p != null) {
+            pending = null;
+            this.total = p.total;
+            this.ids = p.ids;
+            this.items = p.items;
+            this.metas = p.metas;
+            this.counts = p.counts;
+            this.names = p.names;
+            this.rowOffset = p.offset / COLS;
+        }
+        if (this.lastTypeMs != 0 && System.currentTimeMillis() - this.lastTypeMs > 150) {
+            this.lastTypeMs = 0;
+            requestWindow(0);
+        }
+    }
+
+    @Override
+    protected void keyTyped(char ch, int key) {
+        if (key == Keyboard.KEY_ESCAPE) {
+            super.keyTyped(ch, key);
+            return;
+        }
+        if (this.search.textboxKeyTyped(ch, key)) {
+            String t = this.search.getText()
+                .toLowerCase();
+            if (!t.equals(this.keyword)) {
+                this.keyword = t;
+                this.lastTypeMs = System.currentTimeMillis();
+            }
+        } else {
+            super.keyTyped(ch, key);
+        }
+    }
+
+    @Override
+    public void handleMouseInput() {
+        super.handleMouseInput();
+        int dw = Mouse.getEventDWheel();
+        if (dw != 0) {
+            requestWindow(this.rowOffset + (dw > 0 ? -1 : 1));
+        }
+    }
+
+    @Override
+    protected void mouseClicked(int mx, int my, int btn) {
+        super.mouseClicked(mx, my, btn);
+        if (this.search != null) this.search.mouseClicked(mx, my, btn);
+        int relX = mx - this.guiLeft - GRID_X;
+        int relY = my - this.guiTop - GRID_Y;
+        if (relX < 0 || relY < 0) return;
+        int col = relX / SLOT;
+        int row = relY / SLOT;
+        if (col >= COLS || row >= VIS_ROWS) return;
+        int idx = row * COLS + col;
+        ItemStack held = this.mc.thePlayer.inventory.getItemStack();
+        if (held != null) {
+            NetworkHandler.sendAction(3, 0L, 0, this.keyword, this.rowOffset * COLS);
+            return;
+        }
+        if (idx < this.ids.length) {
+            int action;
+            if (btn == 1) action = 1;
+            else if (isShiftKeyDown()) action = 2;
+            else action = 0;
+            NetworkHandler.sendAction(action, this.ids[idx], 0, this.keyword, this.rowOffset * COLS);
+        }
+    }
+
+    @Override
+    protected void actionPerformed(GuiButton b) {
+        if (b.id == 1) {
+            NetworkHandler.sendAction(4, 0L, 0, this.keyword, this.rowOffset * COLS);
+        }
+    }
+
+    @Override
+    protected void drawGuiContainerBackgroundLayer(float pt, int mx, int my) {
+        drawDefaultBackground();
+        int l = this.guiLeft;
+        int t = this.guiTop;
+        drawRect(l, t, l + this.xSize, t + this.ySize, 0xF0202020);
+        drawRect(l + 7, t + 5, l + 159, t + 19, 0xFF000000);
+        if (this.search != null) this.search.drawTextBox();
+        for (int row = 0; row < VIS_ROWS; row++) {
+            for (int col = 0; col < COLS; col++) {
+                int x = l + GRID_X + col * SLOT;
+                int y = t + GRID_Y + row * SLOT;
+                drawRect(x, y, x + 16, y + 16, 0xFF8B8B8B);
+            }
+        }
+        int barX = l + GRID_X + COLS * SLOT + 2;
+        int barTop = t + GRID_Y;
+        int barH = VIS_ROWS * SLOT;
+        drawRect(barX, barTop, barX + 6, barTop + barH, 0xFF000000);
+        int maxRow = maxRowOffset();
+        int handleY = barTop + (maxRow == 0 ? 0 : (int) ((barH - 16) * (this.rowOffset / (double) maxRow)));
+        drawRect(barX, handleY, barX + 6, handleY + 16, 0xFFFFFFFF);
+    }
+
+    @Override
+    protected void drawGuiContainerForegroundLayer(int mx, int my) {
+        int n = Math.min(this.ids.length, VIS_ROWS * COLS);
+        RenderHelper.enableGUIStandardItemLighting();
+        for (int i = 0; i < n; i++) {
+            int col = i % COLS;
+            int row = i / COLS;
+            int x = GRID_X + col * SLOT;
+            int y = GRID_Y + row * SLOT;
+            ItemStack stack = buildStack(i);
+            if (stack != null) {
+                this.renderItem
+                    .renderItemAndEffectIntoGUI(this.fontRendererObj, this.mc.getTextureManager(), stack, x, y);
+                this.renderItem.renderItemOverlayIntoGUI(
+                    this.fontRendererObj,
+                    this.mc.getTextureManager(),
+                    stack,
+                    x,
+                    y,
+                    abbrev(this.counts[i]));
+            }
+        }
+        RenderHelper.disableStandardItemLighting();
+        // tooltip
+        int relX = mx - this.guiLeft - GRID_X;
+        int relY = my - this.guiTop - GRID_Y;
+        if (relX >= 0 && relY >= 0) {
+            int col = relX / SLOT;
+            int row = relY / SLOT;
+            if (col < COLS && row < VIS_ROWS) {
+                int idx = row * COLS + col;
+                if (idx < n) {
+                    ItemStack stack = buildStack(idx);
+                    if (stack != null) {
+                        List<String> tip = new ArrayList<String>();
+                        tip.add(stack.getDisplayName());
+                        tip.add("§7数量: " + this.counts[idx]);
+                        drawHoveringText(tip, mx - this.guiLeft, my - this.guiTop, this.fontRendererObj);
+                        GL11.glDisable(GL11.GL_LIGHTING);
+                    }
+                }
+            }
+        }
+    }
+
+    private ItemStack buildStack(int i) {
+        Object o = Item.itemRegistry.getObject(this.items[i]);
+        if (!(o instanceof Item)) return null;
+        return new ItemStack((Item) o, 1, this.metas[i]);
+    }
+
+    static String abbrev(long n) {
+        if (n >= 1000000L) return String.format("%.1fM", n / 1000000.0);
+        if (n >= 1000L) return String.format("%.1fK", n / 1000.0);
+        return Long.toString(n);
+    }
+}
