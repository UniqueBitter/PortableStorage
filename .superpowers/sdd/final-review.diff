+        if (open.isPressed()) NetworkHandler.openStorage();
+        if (magnet.isPressed()) NetworkHandler.cycleMagnet();
+    }
+}
diff --git a/src/main/java/com/portablestorage/core/MagnetRouter.java b/src/main/java/com/portablestorage/core/MagnetRouter.java
