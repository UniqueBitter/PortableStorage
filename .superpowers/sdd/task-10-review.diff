+package com.portablestorage;
+
+import java.util.ArrayList;
+import java.util.List;
+
+import net.minecraft.entity.player.EntityPlayerMP;
+import net.minecraft.item.ItemStack;
+
+import com.portablestorage.core.StoredItem;
+import com.portablestorage.db.StorageDao;
+import com.portablestorage.item.ItemPortableTerminal;
+import com.portablestorage.item.ItemStackCodec;
+import com.portablestorage.net.NetworkHandler;
+import com.portablestorage.net.PageResultPacket;
+
+public final class StorageService {
+
+    public static final int WINDOW = 90;
+
+    private StorageService() {}
+
+    public static void sendPage(EntityPlayerMP p, String keyword, int offset) {
+        StorageDao dao = StorageProvider.dao();
+        StorageDao.PageResult r = dao.queryWindowWithIds(
+            p.getUniqueID()
+                .toString(),
+            keyword,
+            offset,
+            WINDOW);
+        int n = r.items.size();
+        long[] ids = r.ids;
+        String[] items = new String[n];
+        int[] metas = new int[n];
+        long[] counts = new long[n];
+        String[] names = new String[n];
+        for (int i = 0; i < n; i++) {
+            items[i] = r.items.get(i)
+                .getItem();
+            metas[i] = r.items.get(i)
+                .getMeta();
+            counts[i] = r.items.get(i)
+                .getCount();
+            names[i] = r.items.get(i)
+                .getName();
+        }
+        NetworkHandler.INSTANCE.sendTo(new PageResultPacket(r.total, offset, ids, items, metas, counts, names), p);
+    }
+
+    public static void handleAction(EntityPlayerMP p, int action, long id, int amount, String keyword, int offset) {
+        StorageDao dao = StorageProvider.dao();
+        String uuid = p.getUniqueID()
+            .toString();
+        switch (action) {
+            case 0: // TAKE_STACK
+            case 2: // TAKE_TO_INV (same behavior)
+                takeToInventory(p, dao, uuid, id, -1);
+                break;
+            case 1: // TAKE_ONE
+                takeToInventory(p, dao, uuid, id, 1);
+                break;
+            case 3: // DEPOSIT_CURSOR
+                depositCursor(p, dao, uuid);
+                break;
+            case 4: // QUICK_DEPOSIT_ALL
+                quickDepositAll(p, dao, uuid);
+                break;
+            default:
+                break;
+        }
+        sendPage(p, keyword, offset);
+    }
+
+    private static void takeToInventory(EntityPlayerMP p, StorageDao dao, String uuid, long id, int requested) {
+        StoredItem si = dao.findById(uuid, id);
+        if (si == null) return;
+        int maxStack = ItemStackCodec.decode(si, 1)
+            .getMaxStackSize();
+        int want = requested < 0 ? maxStack : Math.min(requested, maxStack);
+        long took = dao.extract(uuid, id, want);
+        if (took <= 0) return;
+        ItemStack give = ItemStackCodec.decode(si, (int) took);
+        boolean added = p.inventory.addItemStackToInventory(give);
+        if (!added || give.stackSize > 0) {
+            int leftover = give.stackSize;
+            if (leftover > 0) {
+                StoredItem back = si.withCount(leftover);
+                dao.upsert(uuid, back);
+            }
+        }
+        p.inventoryContainer.detectAndSendChanges();
+        if (p.openContainer != null) p.openContainer.detectAndSendChanges();
+    }
+
+    private static void depositCursor(EntityPlayerMP p, StorageDao dao, String uuid) {
+        ItemStack held = p.inventory.getItemStack();
+        if (held == null) return;
+        dao.upsert(uuid, ItemStackCodec.encode(held));
+        p.inventory.setItemStack(null);
+        p.playerNetServerHandler
+            .sendPacket(new net.minecraft.network.play.server.S2FPacketSetSlot(-1, -1, p.inventory.getItemStack()));
+    }
+
+    private static void quickDepositAll(EntityPlayerMP p, StorageDao dao, String uuid) {
+        List<StoredItem> batch = new ArrayList<StoredItem>();
+        for (int i = 0; i < p.inventory.mainInventory.length; i++) {
+            ItemStack st = p.inventory.mainInventory[i];
+            if (st == null) continue;
+            if (st.getItem() instanceof ItemPortableTerminal) continue;
+            batch.add(ItemStackCodec.encode(st));
+            p.inventory.mainInventory[i] = null;
+        }
+        if (!batch.isEmpty()) dao.upsertBatch(uuid, batch);
+        p.inventoryContainer.detectAndSendChanges();
+        if (p.openContainer != null) p.openContainer.detectAndSendChanges();
+    }
+}
